# Required for healing / LLM extraction
GEMINI_API_KEY=

# Optional: default Gemini model id
HEALSCRAPE_GEMINI_MODEL=gemini-2.0-flash

# Data directory (SQLite DB, snapshots, traces)
HEALSCRAPE_DATA_DIR=~/.healscrape

# Database URL (default: sqlite under data dir). PostgreSQL example:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/healscrape

# HTTP client
HEALSCRAPE_HTTP_TIMEOUT_S=30
HEALSCRAPE_MAX_RETRIES=4
HEALSCRAPE_RATE_LIMIT_RPS=2.0

# Healing
HEALSCRAPE_MIN_PROMOTION_CONFIDENCE=0.85
HEALSCRAPE_LLM_MAX_INPUT_CHARS=12000

# Optional HTTP proxy for fetch only (no CAPTCHA / anti-bot)
# HTTPS_PROXY=http://127.0.0.1:8888
